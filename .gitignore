# Ignore everything by default
*

# Track these
!.gitignore
!CLAUDE.md

!agents/
!agents/**
# Exclude GSD agents
agents/gsd-*

!commands/
!commands/**
# Exclude GSD commands
commands/gsd/
!hooks/
!hooks/**
# Exclude GSD hooks
hooks/gsd-*

!rules/
!rules/**
# Exclude MCP rules
rules/mcp-*

# Only track SF, BEF, and bug skills
!skills/
!skills/sf-*/
!skills/sf-*/**
!skills/bef/
!skills/bef/**
!skills/bug-*/
!skills/bug-*/**
