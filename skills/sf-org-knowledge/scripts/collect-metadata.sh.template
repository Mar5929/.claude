#!/usr/bin/env bash
# ============================================================================
# SF Org Knowledge - Metadata Collection Script
# ============================================================================
# Target Org: {{ORG_ALIAS}}
# Generated by: sf-org-knowledge
#
# SAFETY: READ-ONLY OPERATIONS ONLY.
# This script may write files locally under {{RAW_DIR}}, but it must never write
# to the Salesforce org. Deploy, source push, data mutation, org creation, org
# deletion, and any other remote-write commands are forbidden.
# ============================================================================

set -uo pipefail

ORG_ALIAS="{{ORG_ALIAS}}"
RAW_DIR="{{RAW_DIR}}"
MANIFEST_DIR="$RAW_DIR/manifest"
RETRIEVED_DIR="$RAW_DIR/retrieved"
ERRORS=()

log() {
  echo "[sf-org-knowledge] $1"
}

log_error() {
  echo "[sf-org-knowledge] ERROR: $1" >&2
  ERRORS+=("$1")
}

build_selective_manifest() {
  local output_file="$1"
  local found_entries=0
  local api_version="62.0"

  if ! command -v jq >/dev/null 2>&1; then
    log_error "jq not installed; cannot build selective fallback manifest"
    return 1
  fi

  if [ -f "$MANIFEST_DIR/package.xml" ]; then
    DETECTED_VERSION=$(sed -n 's:.*<version>\(.*\)</version>.*:\1:p' "$MANIFEST_DIR/package.xml" | head -n 1)
    if [ -n "$DETECTED_VERSION" ]; then
      api_version="$DETECTED_VERSION"
    fi
  fi

  {
    echo '<?xml version="1.0" encoding="UTF-8"?>'
    echo '<Package xmlns="http://soap.sforce.com/2006/04/metadata">'
  } > "$output_file"

  for LIST_FILE in "$RAW_DIR"/list-*.json; do
    [ -f "$LIST_FILE" ] || continue

    TYPE_NAME=$(basename "$LIST_FILE" .json)
    TYPE_NAME=${TYPE_NAME#list-}

    MEMBERS=$(jq -r '
      .result // []
      | map(.fullName // empty)
      | map(select(. != ""))
      | unique
      | .[]
    ' "$LIST_FILE" 2>/dev/null || true)

    if [ -n "$MEMBERS" ]; then
      found_entries=1
      {
        echo '  <types>'
        while IFS= read -r MEMBER; do
          [ -z "$MEMBER" ] && continue
          echo "    <members>$MEMBER</members>"
        done <<< "$MEMBERS"
        echo "    <name>$TYPE_NAME</name>"
        echo '  </types>'
      } >> "$output_file"
    fi
  done

  {
    echo "  <version>$api_version</version>"
    echo '</Package>'
  } >> "$output_file"

  if [ "$found_entries" -eq 0 ]; then
    log_error "Selective fallback manifest had no members"
    return 1
  fi

  return 0
}

if ! command -v sf >/dev/null 2>&1; then
  echo "ERROR: sf CLI is not installed. Install with: npm install -g @salesforce/cli"
  exit 1
fi

if [ -z "$ORG_ALIAS" ]; then
  echo "ERROR: No org alias provided."
  exit 1
fi

if [ -d "$RAW_DIR" ]; then
  log "Clearing existing raw output"
  find "$RAW_DIR" -mindepth 1 -exec rm -rf {} +
else
  mkdir -p "$RAW_DIR"
fi

log "Validating org connection for $ORG_ALIAS"
if ! sf org display --target-org "$ORG_ALIAS" --json > "$RAW_DIR/org-info.json" 2>/dev/null; then
  echo "ERROR: Cannot connect to org '$ORG_ALIAS'. Run: sf org login web --alias $ORG_ALIAS"
  exit 1
fi

log "Listing metadata types"
sf org list metadata-types --target-org "$ORG_ALIAS" --json \
  > "$RAW_DIR/metadata-types.json" 2>/dev/null || log_error "Failed to list metadata types"

METADATA_TYPES=(
  CustomObject
  CustomField
  Flow
  ApexClass
  ApexTrigger
  ApexPage
  ApexComponent
  ValidationRule
  WorkflowRule
  PermissionSet
  Profile
  ConnectedApp
  NamedCredential
  CustomApplication
  CustomTab
  Layout
  RecordType
  CustomLabel
  RemoteSiteSetting
  ExternalDataSource
  PlatformEventChannel
  FlowDefinition
  ProcessDefinition
  SharingRules
  CustomPermission
  PermissionSetGroup
)

log "Listing metadata components"
for TYPE in "${METADATA_TYPES[@]}"; do
  sf org list metadata --metadata-type "$TYPE" --target-org "$ORG_ALIAS" --json \
    > "$RAW_DIR/list-$TYPE.json" 2>/dev/null || log_error "Failed metadata list for $TYPE"
done

log "Listing sObjects"
sf sobject list --target-org "$ORG_ALIAS" --json \
  > "$RAW_DIR/sobject-list.json" 2>/dev/null || log_error "Failed to list sObjects"

STANDARD_OBJECTS=(
  Account
  Contact
  Opportunity
  Lead
  Case
  Campaign
  Order
  Product2
  PricebookEntry
  Quote
  User
)

log "Describing standard objects"
for OBJ in "${STANDARD_OBJECTS[@]}"; do
  sf sobject describe --sobject "$OBJ" --target-org "$ORG_ALIAS" --json \
    > "$RAW_DIR/describe-$OBJ.json" 2>/dev/null || log_error "Failed describe for $OBJ"
done

log "Describing discovered custom objects"
if [ -f "$RAW_DIR/sobject-list.json" ]; then
  if command -v jq >/dev/null 2>&1; then
    CUSTOM_OBJECTS=$(jq -r '.result[] | select(test("__c$"))' "$RAW_DIR/sobject-list.json" 2>/dev/null || true)
  else
    CUSTOM_OBJECTS=$(grep -oE '"[A-Za-z0-9_]+__c"' "$RAW_DIR/sobject-list.json" 2>/dev/null | tr -d '"' || true)
    log_error "jq not installed; using grep fallback for custom object discovery"
  fi

  if [ -n "$CUSTOM_OBJECTS" ]; then
    while IFS= read -r OBJ; do
      [ -z "$OBJ" ] && continue
      SAFE_NAME=$(echo "$OBJ" | tr '/:' '__')
      sf sobject describe --sobject "$OBJ" --target-org "$ORG_ALIAS" --json \
        > "$RAW_DIR/describe-$SAFE_NAME.json" 2>/dev/null || log_error "Failed describe for $OBJ"
    done <<< "$CUSTOM_OBJECTS"
  fi
else
  log_error "sobject-list.json missing; skipped custom object describes"
fi

log "Running approved SELECT-only Tooling API queries"
sf data query --query "SELECT QualifiedApiName, Label, RecordCount, DeploymentStatus FROM EntityDefinition WHERE IsCustomizable = true ORDER BY RecordCount DESC" \
  --target-org "$ORG_ALIAS" --use-tooling-api --json \
  > "$RAW_DIR/entity-definitions.json" 2>/dev/null || log_error "Failed EntityDefinition query"

sf data query --query "SELECT Name, NamespacePrefix, ApiVersion, Status, LengthWithoutComments, CreatedDate, LastModifiedDate FROM ApexClass ORDER BY Name" \
  --target-org "$ORG_ALIAS" --use-tooling-api --json \
  > "$RAW_DIR/apex-classes.json" 2>/dev/null || log_error "Failed ApexClass query"

sf data query --query "SELECT Name, TableEnumOrId, UsageBeforeInsert, UsageAfterInsert, UsageBeforeUpdate, UsageAfterUpdate, UsageBeforeDelete, UsageAfterDelete, UsageAfterUndelete, Status FROM ApexTrigger" \
  --target-org "$ORG_ALIAS" --use-tooling-api --json \
  > "$RAW_DIR/apex-triggers.json" 2>/dev/null || log_error "Failed ApexTrigger query"

sf data query --query "SELECT DeveloperName, MasterLabel, ProcessType, TriggerType, Description, LastModifiedDate FROM FlowDefinitionView ORDER BY ProcessType, MasterLabel" \
  --target-org "$ORG_ALIAS" --use-tooling-api --json \
  > "$RAW_DIR/flows.json" 2>/dev/null || log_error "Failed FlowDefinitionView query"

sf data query --query "SELECT Name, ContactEmail, Description FROM ConnectedApplication" \
  --target-org "$ORG_ALIAS" --use-tooling-api --json \
  > "$RAW_DIR/connected-apps.json" 2>/dev/null || log_error "Failed ConnectedApplication query"

sf data query --query "SELECT DeveloperName, Endpoint, PrincipalType, Protocol FROM NamedCredential" \
  --target-org "$ORG_ALIAS" --use-tooling-api --json \
  > "$RAW_DIR/named-credentials.json" 2>/dev/null || log_error "Failed NamedCredential query"

sf data query --query "SELECT SubscriberPackageName, SubscriberPackageNamespace, Name, MajorVersion, MinorVersion, PatchVersion FROM InstalledSubscriberPackage" \
  --target-org "$ORG_ALIAS" --use-tooling-api --json \
  > "$RAW_DIR/installed-packages.json" 2>/dev/null || log_error "Failed InstalledSubscriberPackage query"

sf data query --query "SELECT Name, Label, Description, IsCustom, NamespacePrefix, Type FROM PermissionSet WHERE IsOwnedByProfile = false ORDER BY Name" \
  --target-org "$ORG_ALIAS" --use-tooling-api --json \
  > "$RAW_DIR/permission-sets.json" 2>/dev/null || log_error "Failed PermissionSet query"

log "Generating manifest locally"
mkdir -p "$MANIFEST_DIR"
sf project generate manifest --from-org "$ORG_ALIAS" --output-dir "$MANIFEST_DIR" \
  2>/dev/null || log_error "Failed manifest generation"

if [ -f "$MANIFEST_DIR/package.xml" ]; then
  log "Retrieving metadata locally with generated manifest"
  mkdir -p "$RETRIEVED_DIR"
  sf project retrieve start --manifest "$MANIFEST_DIR/package.xml" --target-org "$ORG_ALIAS" --output-dir "$RETRIEVED_DIR" \
    2>/dev/null || log_error "Full metadata retrieval failed; continue with partial atlas"

  if [ ! -d "$RETRIEVED_DIR" ] || [ -z "$(find "$RETRIEVED_DIR" -type f 2>/dev/null | head -n 1)" ]; then
    FALLBACK_MANIFEST="$MANIFEST_DIR/package-selective.xml"
    log "Attempting selective fallback manifest generation"
    if build_selective_manifest "$FALLBACK_MANIFEST"; then
      log "Retrying metadata retrieval with selective fallback manifest"
      sf project retrieve start --manifest "$FALLBACK_MANIFEST" --target-org "$ORG_ALIAS" --output-dir "$RETRIEVED_DIR" \
        2>/dev/null || log_error "Selective fallback retrieval failed"
    else
      log_error "Could not build selective fallback manifest"
    fi
  fi
else
  log_error "package.xml not generated; skipped full retrieve"
fi

JSON_FILE_COUNT=$(find "$RAW_DIR" -type f -name "*.json" | wc -l | tr -d ' ')
ERROR_COUNT=${#ERRORS[@]}

echo ""
echo "============================================"
echo " Collection Complete"
echo "============================================"
echo " Output directory: $RAW_DIR"
echo " JSON files collected: $JSON_FILE_COUNT"
echo " Errors encountered: $ERROR_COUNT"

if [ "$ERROR_COUNT" -gt 0 ]; then
  echo ""
  echo " Errors:"
  for ERR in "${ERRORS[@]}"; do
    echo "  - $ERR"
  done
fi

echo "============================================"
